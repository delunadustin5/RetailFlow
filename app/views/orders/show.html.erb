<div style="font-family: Arial, sans-serif; background-color: #f4f4f4; min-height: 100vh; padding: 40px;">

  <div style="max-width: 800px; margin: 0 auto;">
    <h1>Order #<%= @order.id %></h1>

    <div style="background: white; padding: 20px; margin-bottom: 20px; border-radius: 10px;">
      <p><strong>Total:</strong> $<%= sprintf('%.2f', @order.total) %></p>
      <p><strong>Date:</strong> <%= @order.created_at.strftime("%B %d, %Y %I:%M %p") %></p>
    </div>

    <h2>Items</h2>

    <% @order.order_items.each do |item| %>
      <div style="background: white; padding: 20px; margin-bottom: 15px; border-radius: 10px; box-shadow: 0 2px 8px rgba(0,0,0,0.08);">
        <h3><%= item.product.name %></h3>
        <p><strong>Quantity:</strong> <%= item.quantity %></p>
        <p><strong>Price:</strong> $<%= sprintf('%.2f', item.price) %></p>
        <p><strong>Subtotal:</strong> $<%= sprintf('%.2f', item.price.to_f * item.quantity) %></p>
      </div>
    <% end %>

    <%= link_to "Back to Orders", orders_path, style: "text-decoration: none; color: #007bff; font-weight: bold;" %>
  </div>
</div>