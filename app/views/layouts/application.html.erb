<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Retail Flow" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Retail Flow">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body style="<%= 'background-color: black; color: white;' if controller_name == 'sessions' || controller_name == 'registrations' %>">

  <!-- NAVBAR -->
  <div style="background-color: #ffcc00; border-bottom: 1px solid #d9d9d9; padding: 16px 40px; display: flex; align-items: center; justify-content: space-between; font-family: Arial, sans-serif;">

  <div style="font-size: 34px; font-weight: 700; letter-spacing: -0.5px;">
    <%= link_to "RetailFlow", products_path, style: "text-decoration: none; color: #111;" %>
  </div>

  <div style="display: flex; align-items: center; gap: 36px; font-size: 18px; font-weight: 600;">
    <%= link_to "Products", products_path, style: "text-decoration: none; color: #111;" %>
    <%= link_to "Cart (#{@cart_count})", cart_path, style: "text-decoration: none; color: #111;" %>
    <%= link_to "Orders", orders_path, style: "text-decoration: none; color: #111;" %>
  </div>

  <div style="display: flex; align-items: center; gap: 20px; font-size: 17px; font-weight: 500;">
    <% if user_signed_in? %>
      <span style="color: #333;"><%= current_user.email %></span>

      <%= button_to "Logout", destroy_user_session_path,
          method: :delete,
          style: "background: none; border: none; color: #111; cursor: pointer; font-size: 17px; font-weight: 500; padding: 0;" %>
    <% else %>
      <%= link_to "Login", new_user_session_path, style: "text-decoration: none; color: #111;" %>
      <%= link_to "Sign Up", new_user_registration_path, style: "text-decoration: none; color: #111;" %>
    <% end %>
  </div>

</div>

  <!-- PAGE CONTENT -->
  <% if notice %>
  <div style="background-color: #d4edda; color: #155724; padding: 10px 20px; margin: 0;">
    <%= notice %>
  </div>
<% end %>

<% if alert %>
  <div style="background-color: #f8d7da; color: #721c24; padding: 10px 20px; margin: 0;">
    <%= alert %>
  </div>
<% end %>
  <%= yield %>

</body>
</html>
