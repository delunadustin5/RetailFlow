<div style="font-family: Arial, sans-serif; background-color: #f4f4f4; min-height: 100vh; padding: 0; margin: 0;">

  <div style="background-color: #222; color: white; padding: 20px 40px; display: flex; justify-content: space-between; align-items: center;">
    <h1 style="margin: 0;">RetailFlow</h1>
    <div>
      <%= link_to "Products", products_path, style: "color: white; margin-right: 20px; text-decoration: none; font-weight: bold;" %>
      <%= link_to "Cart", cart_path, style: "color: white; margin-right: 20px; text-decoration: none; font-weight: bold;" %>
      <%= link_to "Orders", orders_path, style: "color: white; text-decoration: none; font-weight: bold;" %>
    </div>
  </div>

  <div style="padding: 30px 40px;">
    <% if notice %>
      <p style="color: green; font-weight: bold; background: #e6ffe6; padding: 10px; border: 1px solid #b2d8b2; border-radius: 5px;">
        <%= notice %>
      </p>
    <% end %>

    <div style="margin-bottom: 25px;">
      <%= form_with url: products_path, method: :get, local: true do %>

      <%= text_field_tag :search, params[:search], placeholder: "Search products...",
        style: "padding: 10px; width: 250px; border: 1px solid #ccc; border-radius: 5px;" %>

      <%= select_tag :category,
        options_for_select(Product.pluck(:category).uniq, params[:category]),
        include_blank: "All Categories",
        style: "padding: 10px; margin-left: 8px; border-radius: 5px;" %>

      <%= submit_tag "Search",
        style: "background-color: #007bff; color: white; padding: 10px 14px; border: none; border-radius: 5px; font-weight: bold; cursor: pointer; margin-left: 8px;" %>

      <% end %>
    </div>

    <h2 style="margin-bottom: 25px;">Available Products</h2>

<% if @products.any? %>
  <div style="display: flex; flex-wrap: wrap; gap: 20px;">
    <% @products.each do |product| %>
      <% next unless product %>

      <div style="background: white; border: 1px solid #ddd; border-radius: 10px; width: 250px; padding: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.08);">

        <% if product.image.present? %>
          <img src="<%= product.image %>" style="width: 100%; height: 150px; object-fit: cover; border-radius: 8px; margin-bottom: 10px;">
        <% end %>

        <h3 style="margin-top: 0;">
          <%= link_to product.name, product, style: "text-decoration: none; color: #222;" %>
        </h3>

        <p style="color: #666;"><%= product.description %></p>
        <p><strong>Category:</strong> <%= product.category %></p>
        <p><strong>Price:</strong> $<%= sprintf('%.2f', product.price) %></p>
        <p><strong>Stock:</strong> <%= product.stock %></p>

        <div style="margin-top: 15px;">
          <%= link_to "View Product", product, style: "display: inline-block; background-color: #007bff; color: white; padding: 10px 14px; border-radius: 5px; text-decoration: none; font-weight: bold;" %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <p>No products found.</p>
<% end %>
    </div>
  </div>
</div>