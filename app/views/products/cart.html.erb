<div style="font-family: Arial, sans-serif; background-color: #f4f4f4; min-height: 100vh; padding: 40px;">

  <div style="max-width: 800px; margin: 0 auto;">
    <h1>Your Cart</h1>

    <% total = 0 %>

    <% if @cart_items.any? %>
      <% @cart_items.each do |item| %>
        <% product = item[:product] %>
        <% quantity = item[:quantity].to_i %>
        <% subtotal = product.price.to_f * quantity %>

        <div style="background: white; padding: 20px; margin-bottom: 20px; border-radius: 10px; box-shadow: 0 2px 8px rgba(0,0,0,0.08);">
          <h2><%= product.name %></h2>
          <p><%= product.description %></p>
          <p><strong>Price:</strong> $<%= sprintf('%.2f', product.price) %></p>
          <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 10px;">
            <strong>Quantity:</strong>

            <%= button_to "-", decrease_quantity_path(product.id), method: :post,
            style: "background-color: #dc3545; color: white; border: none; padding: 6px 10px; border-radius: 4px; cursor: pointer;" %>

            <span><%= quantity %></span>

            <%= button_to "+", increase_quantity_path(product.id), method: :post,
             style: "background-color: #28a745; color: white; border: none; padding: 6px 10px; border-radius: 4px; cursor: pointer;" %>
            </div>
            
          <p><strong>Subtotal:</strong> $<%= sprintf('%.2f', subtotal) %></p>

          <%= button_to "Remove", remove_from_cart_path(product.id), method: :post,
              style: "background-color: #dc3545; color: white; padding: 10px 14px; border: none; border-radius: 5px; font-weight: bold; cursor: pointer;" %>
        </div>

        <% total += subtotal %>
      <% end %>

      <div style="background: white; padding: 20px; border-radius: 10px; box-shadow: 0 2px 8px rgba(0,0,0,0.08);">
        <h2>Total: $<%= sprintf('%.2f', total) %></h2>

        <%= button_to "Checkout", checkout_path, method: :post,
            style: "background-color: #28a745; color: white; padding: 12px 18px; border: none; border-radius: 5px; font-weight: bold; cursor: pointer; margin-top: 10px;" %>
      </div>
    <% else %>
      <p>Your cart is empty.</p>
    <% end %>

    <div style="margin-top: 20px;">
      <%= link_to "Continue Shopping", products_path, style: "text-decoration: none; color: #007bff; font-weight: bold;" %>
    </div>
  </div>
</div>